<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="30"
      data-width="1080"
      data-height="1920"
    >
      <!-- BEAT 1 — HOOK (0–3s) -->
      <div id="b1" class="clip beat" data-start="0" data-duration="3" data-track-index="0">
        <div class="bg-image">
          <img src="../assets/images/generated/post_20260405_152427.jpg" alt="" />
          <div class="vignette"></div>
        </div>
        <div class="logo-bar">
          <span class="divider"></span>
          <span class="logo">GENZ CAPITAL</span>
          <span class="divider"></span>
        </div>
        <div class="hook-text">
          <div class="line line-1">GEN Z IS REBELLING</div>
          <div class="line line-2 neon">TEN THOUSAND</div>
          <div class="line line-3">MONTHLY WITH AI</div>
          <div class="subline">HARNESS THE POWER OF AUTOMATION</div>
        </div>
      </div>

      <!-- BEAT 2 — PROBLEM (3–10s) -->
      <div id="b2" class="clip beat" data-start="3" data-duration="7" data-track-index="0">
        <div class="bg-image">
          <img src="../assets/images/generated/post_20260406_125909.jpg" alt="" />
          <div class="vignette dark"></div>
        </div>
        <div class="problem-text">
          <div class="problem-line a">THE REASON?</div>
          <div class="problem-line b">FRUSTRATED WITH JOB LOSS FEARS?</div>
        </div>
      </div>

      <!-- BEAT 3 — INSIGHT (10–20s) -->
      <div id="b3" class="clip beat" data-start="10" data-duration="10" data-track-index="0">
        <div class="bg-image">
          <img src="../assets/images/generated/post_20260406_131958.jpg" alt="" />
          <div class="vignette"></div>
        </div>
        <div class="insight-text">
          <div class="insight-line a">WE’RE TURNING SKEP</div>
          <div class="insight-line b neon">TEN THOUSAND</div>
          <div class="insight-line c">IT’S OUR TIME TO R</div>
        </div>
      </div>

      <!-- BEAT 4 — PROOF (20–27s) -->
      <div id="b4" class="clip beat" data-start="20" data-duration="7" data-track-index="0">
        <div class="black-bg"></div>
        <div class="proof-block">
          <div class="proof-number neon">$10,000</div>
          <div class="proof-label">HARNESS THE POWER OF AUTOMATION</div>
        </div>
      </div>

      <!-- BEAT 5 — CTA (27–30s) -->
      <div id="b5" class="clip beat" data-start="27" data-duration="3" data-track-index="0">
        <div class="bg-image">
          <img src="../assets/images/generated/post_20260406_132242.jpg" alt="" />
          <div class="vignette"></div>
        </div>
        <div class="cta-block">
          <div class="cta-divider"></div>
          <div class="cta-line save">SAVE THIS.</div>
          <div class="cta-line follow">FOLLOW @genzcapital</div>
        </div>
        <div class="logo-corner">GENZ CAPITAL</div>
      </div>
      <audio id="vo" data-start="0" data-duration="30" data-track-index="1" data-volume="1.0" src="assets/audio/how-gen-z-is-making-0k-month-with-ai-202_voiceover.mp3"></audio>
    </div>

    <script src="script.js"></script>
    <script>
      window.__timelines = window.__timelines || {};
      if (!window.__timelines['main']) {
        window.__timelines['main'] = (window.gsap || { timeline: () => ({}) }).timeline({ paused: true });
      }
    </script>
  </body>
</html>
