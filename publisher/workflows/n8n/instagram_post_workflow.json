    {
      "parameters": {
        "jsCode": "// Extract the image URL from DALL-E response and merge with previous data\nconst dalleResponse = $input.item.json;\nconst prevData = $('Code - Parse OpenAI Output').item.json;\n\nconst imageUrl = dalleResponse.data?.[0]?.url || dalleResponse.url || '';\n\nif (!imageUrl) {\n  throw new Error('No image URL from DALL-E. Response: ' + JSON.stringify(dalleResponse));\n}\n\nreturn {\n  ...prevData,\n  dalle_image_url: imageUrl\n};"
      },
