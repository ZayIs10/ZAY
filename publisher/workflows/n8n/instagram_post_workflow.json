        "jsCode": "// Extract post ID and build permalink\nconst igResp = $input.item.json;\nconst postId = igResp.id || '';\nconst prevData = $('Code - Extract Container ID').item.json;\n\nreturn {\n  row_number: prevData.row_number,\n  post_id: postId,\n  post_url: postId ? `https://www.instagram.com/p/${postId}/` : 'N/A',\n  published_date: new Date().toISOString().split('T')[0]\n};"
