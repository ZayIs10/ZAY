      "id": "node_p2_get_rows",
      "name": "Google Sheets - Get All Rows",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [480, 400]
    },
    {
      "parameters": {
        "jsCode": "// Find the first row with Status = 'Ready'\nconst rows = $input.all();\nlet readyRow = null;\n\nfor (const row of rows) {\n  const status = (row.json.Status || '').trim();\n  if (status === 'Ready') {\n    readyRow = row.json;\n    break;\n  }\n}\n\nif (!readyRow) {\n  return [{ found: false, message: 'No ready topics in sheet' }];\n}\n\nreturn [{\n  found: true,\n  row_number: readyRow.row_number || readyRow.__rowNumber || '',\n  topic: readyRow.Topic || '',\n  key_points: readyRow['Key Points'] || '',\n  brand_tone: readyRow['Brand Tone'] || 'Gen Z Capital: Bold, cinematic, dark aesthetic.',\n  enriched_context: readyRow['Enriched Context'] || '',\n  post_type: readyRow['Post Type'] || 'single',\n  headline_line1: readyRow['Headline Line 1'] || '',\n  headline_line2: readyRow['Headline Line 2'] || '',\n  headline_line3: readyRow['Headline Line 3'] || '',\n  subheadline: readyRow['Subheadline'] || '',\n  cta: readyRow['CTA'] || 'Save this.'\n}];"
      },
      "id": "node_p3_find_ready",
      "name": "Code - Find First Ready Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 400]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.found }}",
              "value2": true
            }
          ]
        }
      },
      "id": "node_p4_if_found",
      "name": "IF - Has Ready Topic?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [960, 400]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a Gen Z social media copywriter AND a cinematic art director. You write for Gen Z Capital — a dark luxury wealth/AI brand. Style: direct, serious, high-stakes, NO hype, NO emojis. Neon green energy. Output ONLY a valid JSON object."
            },
            {
              "role": "user",
              "content": "=Topic: {{ $json.topic }}\nKey Points: {{ $json.key_points }}\nBrand Tone: {{ $json.brand_tone }}\nContext: {{ $json.enriched_context }}\n\nExisting headline (use if good, or improve):\n- Line 1 (white): {{ $json.headline_line1 }}\n- Line 2 (neon green): {{ $json.headline_line2 }}\n- Line 3 (white): {{ $json.headline_line3 }}\n- Subheadline (gray): {{ $json.subheadline }}\n\nGenerate a JSON object with exactly these keys:\n1. post_caption: High-impact Instagram caption. Punchy. Use real facts from context. Max 150 words. No emojis.\n2. headline_line1: UPPERCASE, max 5 words, white text, the SETUP hook\n3. headline_line2: UPPERCASE, max 4 words, NEON GREEN text, the KEY STAT or POWER WORD\n4. headline_line3: UPPERCASE, max 5 words, white text, the CONSEQUENCE\n5. subheadline: lowercase, max 12 words, gray text\n6. dalle_prompt: Cinematic DALL-E 3 prompt. Dark, moody, ultra-realistic. Specific to topic. No faces. No text in image. Shot on RED Komodo 6K, anamorphic lens, deep shadows. Max 80 words.\n\nReturn ONLY the JSON object."
            }
          ]
        },
        "options": {
          "temperature": 0.8,
          "response_format": { "type": "json_object" }
        }
      },
      "id": "node_p5_openai_caption",
      "name": "OpenAI - Generate Caption & Image Prompt",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.4,
      "position": [1200, 280]
    },
    {
      "parameters": {
        "jsCode": "// Parse OpenAI output and pass topic data downstream\nlet raw;\ntry {\n  let content = $input.item.json.message?.content || $input.item.json.choices?.[0]?.message?.content || '{}';\n  // Strip markdown code fences if OpenAI wraps response in ```json ... ```\n  content = content.replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```$/, '').trim();\n  raw = JSON.parse(content);\n} catch (e) {\n  throw new Error('Failed to parse OpenAI JSON: ' + e.message);\n}\n\nconst prevNode = $('Code - Find First Ready Row').item.json;\n\nreturn {\n  row_number: prevNode.row_number,\n  topic: prevNode.topic,\n  post_type: prevNode.post_type,\n  post_caption: raw.post_caption || '',\n  headline_line1: (raw.headline_line1 || '').toUpperCase(),\n  headline_line2: (raw.headline_line2 || '').toUpperCase(),\n  headline_line3: (raw.headline_line3 || '').toUpperCase(),\n  subheadline: (raw.subheadline || '').toLowerCase(),\n  dalle_prompt: raw.dalle_prompt || `Cinematic dark luxury scene related to ${prevNode.topic}. Deep shadows. No text. No faces. Shot on RED Komodo 6K anamorphic lens.`\n};"
      },
      "id": "node_p6_parse_output",
      "name": "Code - Parse OpenAI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 280]
