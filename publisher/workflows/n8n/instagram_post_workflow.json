            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Bannerbear - Format & Overlay Text": {
      "main": [
        [
          {
            "node": "Instagram - Publish Post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Instagram - Publish Post": {
      "main": [
        [
          {
            "node": "Google Sheets - Update Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "meta": {
