        "jsCode": "// Extract container ID and merge with row data\nconst igResponse = $input.item.json;\nconst containerId = igResponse.id || '';\n\nif (!containerId) {\n  throw new Error('Instagram container creation failed: ' + JSON.stringify(igResponse));\n}\n\nconst prevData = $('Code - Extract Litterbox URL').item.json;\n\nreturn {\n  ...prevData,\n  container_id: containerId\n};"
