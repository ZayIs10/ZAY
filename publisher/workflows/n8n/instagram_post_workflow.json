    {
      "parameters": {
        "jsCode": "// Extract the Litterbox public URL\nconst resp = $input.item.json;\nconst url = (resp.data || resp.body || '').trim();\n\nif (!url.startsWith('http')) {\n  throw new Error('Litterbox upload failed. Response: ' + JSON.stringify(resp));\n}\n\nconst prevData = $('Code - Parse OpenAI Output').item.json;\n\nreturn {\n  ...prevData,\n  final_image_url: url,\n  imgbb_page: url\n};"
      },
