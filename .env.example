# Gen Z Automation — API Keys Template
# Copy this file to .env and fill in your real keys

OPENAI_API_KEY=your_openai_api_key_here

APIFY_API_TOKEN=your_apify_token_here

SERPER_API_KEY=your_serper_api_key_here

YOUTUBE_API_KEY=your_youtube_api_key_here

INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_IG_USER_ID=your_instagram_user_id_here

GOOGLE_SHEET_ID=your_google_sheet_id_here

IMGBB_API_KEY=your_imgbb_api_key_here

# Pexels — copyright-safe stock photos for reel backgrounds.
# Free tier: 200 requests/hour, 20K/month. Sign up: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Usage guards (stops automation before over-usage)
OPENAI_DAILY_BUDGET_USD=10
OPENAI_MONTHLY_BUDGET_USD=200
OPENAI_RUN_BUDGET_USD=2
OPENAI_MAX_REQUESTS_PER_RUN=25
OPENAI_MAX_TOKENS_PER_RUN=100000

# Cost estimates (adjust to your model pricing)
OPENAI_INPUT_COST_PER_1M_USD=5
OPENAI_OUTPUT_COST_PER_1M_USD=15
OPENAI_IMAGE_STANDARD_COST_USD=0.04
OPENAI_IMAGE_HD_COST_USD=0.08
