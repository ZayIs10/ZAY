name: Gen Z Capital — Daily Post Pipeline

# Runs 3x per day (UTC+8 / Malaysia-Singapore time):
#   08:00 AM local = 00:00 UTC  -> research + publish
#   01:00 PM local = 05:00 UTC  -> research + publish
#   06:00 PM local = 10:00 UTC  -> research + publish
#
# To change times: edit the cron lines below (uses UTC)

on:
  schedule:
    - cron: '0 0 * * *'    # 8:00 AM UTC+8 — once per day
  workflow_dispatch:        # allow manual trigger from GitHub UI

jobs:
  research-and-publish:
    runs-on: ubuntu-latest
    timeout-minutes: 90

    env:
      OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      INSTAGRAM_ACCESS_TOKEN: ${{ secrets.INSTAGRAM_ACCESS_TOKEN }}
      INSTAGRAM_IG_USER_ID: ${{ secrets.INSTAGRAM_IG_USER_ID }}
      GOOGLE_SHEET_ID: ${{ secrets.GOOGLE_SHEET_ID }}
      IMGBB_API_KEY: ${{ secrets.IMGBB_API_KEY }}
      YOUTUBE_API_KEY: ${{ secrets.YOUTUBE_API_KEY }}
      SERPER_API_KEY: ${{ secrets.SERPER_API_KEY }}
      APIFY_API_TOKEN: ${{ secrets.APIFY_API_TOKEN }}

    steps:
      # -----------------------------------------------------------------------
      # 1. Get the code
      # -----------------------------------------------------------------------
      - name: Checkout repository
        uses: actions/checkout@v4

      # -----------------------------------------------------------------------
      # 2. Python setup
      # -----------------------------------------------------------------------
      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install dependencies
        run: pip install -r requirements.txt

      # -----------------------------------------------------------------------
      # 3. Rebuild secret files from GitHub Secrets
      # -----------------------------------------------------------------------
      - name: Create .env file
        run: |
          printf "OPENAI_API_KEY=%s\n" "$OPENAI_API_KEY" >> .env
          printf "INSTAGRAM_ACCESS_TOKEN=%s\n" "$INSTAGRAM_ACCESS_TOKEN" >> .env
          printf "INSTAGRAM_IG_USER_ID=%s\n" "$INSTAGRAM_IG_USER_ID" >> .env
          printf "GOOGLE_SHEET_ID=%s\n" "$GOOGLE_SHEET_ID" >> .env
          printf "IMGBB_API_KEY=%s\n" "$IMGBB_API_KEY" >> .env
          printf "YOUTUBE_API_KEY=%s\n" "$YOUTUBE_API_KEY" >> .env
          printf "SERPER_API_KEY=%s\n" "$SERPER_API_KEY" >> .env
          printf "APIFY_API_TOKEN=%s\n" "$APIFY_API_TOKEN" >> .env

      - name: Create google_service_account.json
        run: |
          echo '${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}' > google_service_account.json
          echo "Created at: $(pwd)/google_service_account.json"
          ls -la google_service_account.json

      # -----------------------------------------------------------------------
      # 4. Verify secrets are present (safe check — never prints values)
      # -----------------------------------------------------------------------
      - name: Verify required secrets are set
        run: |
          echo "=== Secret presence check (values are hidden) ==="
          [ -n "$OPENAI_API_KEY" ]            && echo "OPENAI_API_KEY        ✓" || echo "OPENAI_API_KEY        ✗ MISSING"
          [ -n "$INSTAGRAM_ACCESS_TOKEN" ]     && echo "INSTAGRAM_ACCESS_TOKEN ✓" || echo "INSTAGRAM_ACCESS_TOKEN ✗ MISSING"
          [ -n "$INSTAGRAM_IG_USER_ID" ]       && echo "INSTAGRAM_IG_USER_ID  ✓" || echo "INSTAGRAM_IG_USER_ID  ✗ MISSING"
          [ -n "$GOOGLE_SHEET_ID" ]            && echo "GOOGLE_SHEET_ID       ✓" || echo "GOOGLE_SHEET_ID       ✗ MISSING"
          [ -n "$IMGBB_API_KEY" ]              && echo "IMGBB_API_KEY         ✓" || echo "IMGBB_API_KEY         ✗ MISSING"
          python3 -c "
          import json, sys
          try:
              d = json.load(open('google_service_account.json'))
              print('google_service_account.json ✓ (type:', d.get('type','?'), ')')
          except Exception as e:
              print('google_service_account.json ✗', e)
              sys.exit(1)
          "

      # -----------------------------------------------------------------------
      # 5. Research phase — find 1 fresh topic, write to Google Sheets
      #    NOTE: no continue-on-error — a real failure shows as RED in GitHub
      # -----------------------------------------------------------------------
      - name: Run research (1 topic)
        id: research
        run: |
          mkdir -p logs
          cd research
          python research.py --count 1 2>&1 | tee ../logs/research_run.log
          RESEARCH_EXIT=${PIPESTATUS[0]}

          # Count how many rows were actually written
          ROWS_WRITTEN=$(grep -oP "Wrote \K[0-9]+" ../logs/research_run.log 2>/dev/null || echo "0")
          echo "rows_written=$ROWS_WRITTEN" >> $GITHUB_OUTPUT

          echo ""
          echo "========================================="
          if [ "$ROWS_WRITTEN" -gt "0" ]; then
            echo "✅ RESEARCH SUCCESS — wrote $ROWS_WRITTEN topic(s) to Google Sheets"
          else
            echo "❌ RESEARCH FAILED — 0 topics written to Google Sheets"
            echo "Most likely cause: OpenAI quota exhausted (429) or API key issue."
            echo "Check: https://platform.openai.com/account/billing"
            exit 1
          fi
          echo "========================================="

      # -----------------------------------------------------------------------
      # 6. Wait 30 seconds for Google Sheets to sync
      # -----------------------------------------------------------------------
      - name: Wait for Sheets sync
        run: sleep 30

      # -----------------------------------------------------------------------
      # 7. Publisher phase — generate image + post to Instagram
      # -----------------------------------------------------------------------
      - name: Run publisher
        run: |
          mkdir -p logs
          cd publisher
          python post_generator.py 2>&1 | tee ../logs/publisher_run.log
          PUBLISHER_EXIT=${PIPESTATUS[0]}

          echo ""
          echo "========================================="
          if grep -q "Post published" ../logs/publisher_run.log 2>/dev/null; then
            POST_URL=$(grep -oP "Post URL: \K\S+" ../logs/publisher_run.log | tail -1)
            echo "✅ PUBLISHER SUCCESS — post live: $POST_URL"
          elif grep -q "No topics with Status='Ready'" ../logs/publisher_run.log 2>/dev/null; then
            echo "⚠️  PUBLISHER SKIPPED — no Ready topics found in Google Sheets"
            echo "Research may have failed or sheet is empty."
          else
            echo "❌ PUBLISHER FAILED — check logs above"
          fi
          echo "========================================="

          exit $PUBLISHER_EXIT

      # -----------------------------------------------------------------------
      # 8. Upload logs as artifacts (downloadable from GitHub for debugging)
      # -----------------------------------------------------------------------
      - name: Upload logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: pipeline-logs-${{ github.run_id }}
          path: logs/
          retention-days: 14
